# ---- Devin API (v1) ----
# Personal API key (apk_user_*) or service key (apk_*)
DEVIN_API_KEY=apk_user_xxxxxxxxxxxxxxxx
DEVIN_API_BASE=https://api.devin.ai/v1
# Cap spend per session so a runaway fix can't burn your budget.
DEVIN_MAX_ACU_LIMIT=10
# Set to 1 to run the whole pipeline end-to-end with a simulated Devin
# (no API key, no spend). Great for the recorded demo and CI.
DEVIN_MOCK=1
# In mock mode, how long a session "works" before opening a PR (seconds).
DEVIN_MOCK_WORK_SECONDS=20

# ---- GitHub ----
# Your FORK, as owner/repo (e.g. catherine-zhao/superset)
GITHUB_REPO=your-org/superset
# Token with repo scope (used to comment PR links back onto issues + create issues)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx
GITHUB_API_BASE=https://api.github.com
# Shared secret configured on the GitHub webhook (Settings > Webhooks)
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string

# ---- Pipeline behavior ----
# Only issues carrying this label are remediated.
TRIGGER_LABEL=devin-fix
# How often the poller reconciles open sessions (seconds).
POLL_INTERVAL_SECONDS=10
# SQLite location (mounted to a volume in docker-compose).
DB_PATH=/data/autofix.db
# Set to 0 to disable the in-process background poller (run cli.py poll instead).
RUN_POLLER=1
